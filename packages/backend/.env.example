PORT=4000
CORS_ORIGIN=http://localhost:5173

# Admin dashboard token (optional)
# ADMIN_TOKEN=your-secret-admin-token

# ── Gmail SMTP for webdev.2301@gmail.com ─────────────────────────────
# Step 1: Sign in to webdev.2301@gmail.com
# Step 2: Google Account → Security → turn ON "2-Step Verification"
# Step 3: Google Account → Security → App passwords → create one for "Mail"
# Step 4: Copy the 16-character password (no spaces) into SMTP_PASS below
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=webdev.2301@gmail.com
SMTP_PASS=paste-your-16-char-app-password-here

# Contact form emails land in this inbox
MAIL_TO=webdev.2301@gmail.com
MAIL_FROM="BrandSpire Website" <webdev.2301@gmail.com>

# Optional: custom logo file path (defaults to frontend/public/brandspire-logo.svg)
# MAIL_LOGO_PATH=
